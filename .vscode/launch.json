{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tackle Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../tackle-dogfood",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": ["${workspaceFolder}/packages/extension/dist/**/*.js"],
      "preLaunchTask": "compile-extension"
    }
  ]
}
