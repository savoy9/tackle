{
  "name": "tackle",
  "displayName": "Tackle",
  "description": "Task-scoped workspace manager for VS Code",
  "version": "0.1.0",
  "publisher": "tackle",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./dist/extension.js",
  "enabledApiProposals": ["terminalDataWriteEvent"],
  "contributes": {
    "configuration": {
      "title": "Tackle",
      "properties": {
        "tackle.defaultAgent": {
          "type": "string",
          "default": "agency-cc",
          "description": "Default Agent used when creating a new Session. Built-in options: 'agency-cc' (Microsoft-internal Claude Code wrapper) or 'claude' (vanilla Claude Code). Per-session 'agent' values override this."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tackle",
          "title": "Tackle",
          "icon": "resources/tackle.svg"
        }
      ]
    },
    "views": {
      "tackle": [
        {
          "id": "tackleSidebar",
          "name": "Tackle",
          "type": "webview"
        },
        {
          "id": "tackleSessionView",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "tackle.helloWorld",
        "title": "Tackle: Hello World"
      },
      {
        "command": "tackle.activate",
        "title": "Tackle: Activate"
      },
      {
        "command": "tackle.deactivate",
        "title": "Tackle: Deactivate"
      },
      {
        "command": "tackle.syncTasks",
        "title": "Tackle: Sync Tasks",
        "icon": "$(sync)"
      },
      {
        "command": "tackle.selectTask",
        "title": "Tackle: Select Task"
      },
      {
        "command": "tackle.focusSession",
        "title": "Tackle: Focus Session"
      },
      {
        "command": "tackle.newSession",
        "title": "Tackle: New Session",
        "icon": "$(add)"
      },
      {
        "command": "tackle.benchmark",
        "title": "Tackle: Run Terminal Latency Benchmark"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tackle.syncTasks",
          "when": "view == tackleSidebar",
          "group": "navigation"
        },
        {
          "command": "tackle.newSession",
          "when": "view == tackleSessionView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "bun build src/extension.ts --outdir dist --target node --format cjs --external vscode --external better-sqlite3 --external node:sqlite && bun build src/sidebar/webview/main.ts --outdir dist --target browser --format iife --entry-naming sidebar-webview.js",
    "compile:tests": "bun build ./test/runner/run-bench.ts ./test/suite/index.ts ./test/bench/latency.test.ts --outdir out-test --target node --format cjs --external vscode --external better-sqlite3 --external node:sqlite --external mocha --external glob --external @vscode/test-electron",
    "typecheck": "tsc --noEmit",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "test:bench": "bun run compile && bun run compile:tests && node out-test/runner/run-bench.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "@tackle/shared": "workspace:*",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "glob": "^11.0.0",
    "mocha": "^10.8.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
