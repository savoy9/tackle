{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tackle Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../../../tackle-dogfood",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "compile"
    }
  ]
}
