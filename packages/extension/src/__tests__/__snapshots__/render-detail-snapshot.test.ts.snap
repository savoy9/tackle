  <button class="icon-btn overflow" title="More" data-action="sessionOverflow" data-session-id="10">⋯</button>
</div><div class="session-row" data-action="focusSession" data-session-id="11">
  <span class="kind">⌨️</span>
  <span class="label">done</span>
  <span class="glyph">✔️</span>
  <button class="icon-btn stop" title="Stop" data-action="stopSession" data-session-id="11">⏹</button>
  <button class="icon-btn done" title="Mark Done" data-action="markSessionDone" data-session-id="11">✓</button>
  <button class="icon-btn overflow" title="More" data-action="sessionOverflow" data-session-id="11">⋯</button>
</div></div>
  </div>
  <div class="detail-footer"><hr class="detail-footer-rule" /><ul class="detail-footer-list"><li class="detail-footer-row" data-action="switchDetailTo" data-task-id="2" title="Other A">
      <span class="glyph">○</span>
      <span class="title">Other A</span>
      <span class="id">#2</span>
    </li><li class="detail-footer-row" data-action="switchDetailTo" data-task-id="3" title="Other B">
      <span class="glyph">○</span>
      <span class="title">Other B</span>
      <span class="id">#3</span>
    </li></ul></div>
</div></body></html>"
`;
